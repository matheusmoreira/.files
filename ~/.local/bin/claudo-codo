# ---------------------------------------------------------------------------
# Binary discovery
# ---------------------------------------------------------------------------

def discover() -> list[Path]:
    """Find the Claude Code binaries that will actually run.

    Only patches binaries that are reachable — the one PATH resolves to,
    plus any npm-installed binaries.  Old versioned binaries left behind
    by the native installer are ignored so they can't block launch.
    """
    found: set[Path] = set()
    home = Path.home()

    # PATH resolution — finds whichever binary `claude` would exec.
    # For the native installer this resolves through the symlink into
    # ~/.local/share/claude/versions/<hash>, which is the real target.
    claude = shutil.which('claude')
    if claude is not None:
        resolved = Path(claude).resolve()
        if resolved.is_file():
            found.add(resolved)

    # npm global installs
    for npm_root in (home / '.npm-global' / 'lib' / 'node_modules',
                     Path('/usr/local/lib/node_modules'),
                     Path('/usr/lib/node_modules')):
        ant = npm_root / '@anthropic-ai'
        if ant.is_dir():
            for package in ant.iterdir():
                if package.name.startswith('claude-code-'):
                    candidate = package / 'claude'
                    if candidate.is_file():
                        found.add(candidate.resolve())

    return sorted(found)


# ---------------------------------------------------------------------------
# Analyze and apply
# ---------------------------------------------------------------------------

def analyze(patches: list[Patch], data: bytes) -> list[Result]:
    """Classify every patch against binary data.  Pure — no mutation."""
    return [p.classify(data) for p in patches]


def backup(path: Path) -> None:
    """Create a .original backup if one doesn't already exist."""
    dest = path.with_name(path.name + '.original')
    if not dest.exists():
        shutil.copy2(path, dest)


def patch_binary(patches: list[Patch], path: Path) -> tuple[list[Result], bool]:
    """Analyze and conditionally patch one binary.

    Returns (results, success).  Only applies patches when every target is
    present — never leaves a binary in a partially-patched state.
    Backup is created only when we actually write changes.
    """
    data = bytearray(path.read_bytes())
    results = analyze(patches, data)

    applicable = any(r.status is Status.APPLICABLE for r in results)
    missing    = any(r.status is Status.MISSING    for r in results)

    if applicable and not missing:
        backup(path)
        total = sum(p.apply_to(data) for p in patches)
        if total:
            path.write_bytes(bytes(data))

    return results, not missing


# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

ENV_SET = {
    'DISABLE_AUTOUPDATER':              '1',     # pin version so patches stick
    'ENABLE_TOOL_SEARCH':               '1',     # deferred tool loading
    'CLAUDE_CODE_EFFORT_LEVEL':         'max',   # top tier; falls back to high on older models
    'CLAUDE_CODE_ALWAYS_ENABLE_EFFORT': '1',     # honor effort even on models the allowlist would skip
    'CLAUDE_CODE_INVESTIGATE_FIRST':    'additive', # investigate before asking clarifying questions (4.7)
    'MAX_THINKING_TOKENS':              '128000', # server clamps to model max
    'CLAUDE_CODE_MAX_OUTPUT_TOKENS':    '128000',
    'API_TIMEOUT_MS':                   '600000',
    'CLAUDE_STREAM_IDLE_TIMEOUT_MS':    '300000',
    'DISABLE_TELEMETRY':                '1',     # no background phone-home
    'DISABLE_ERROR_REPORTING':          '1',
    'DISABLE_GROWTHBOOK':               '1',     # block feature flag SDK (remote prompt injection vector)
    'CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC': '1', # also blocks metrics pipeline
}

ENV_CLEAR = [
    'CLAUDE_CODE_DISABLE_THINKING',
    'CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING',
    'DISABLE_INTERLEAVED_THINKING',
    'CLAUDE_CODE_BRIEF',
    'CLAUDE_CODE_BRIEF_UPLOAD',
    'CLAUDE_CODE_SIMPLE',
    'CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT',
]


def configure_env() -> None:
    """Set capability env vars and clear any that would suppress features."""
    os.environ.update(ENV_SET)
    for var in ENV_CLEAR:
        os.environ.pop(var, None)


# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------

def report_binary(path: Path, results: list[Result], ok: bool) -> None:
    """Print per-patch status for a single binary."""
    symbol = '✓' if ok else '✗'
    print(f"claudo-codo: {symbol} {path}", file=sys.stderr)
    for r in results:
        print(f"  {r.status.value:>10s} ({r.occurrences}x)  {r.label}",
              file=sys.stderr)
    a = sum(1 for r in results if r.status is Status.APPLICABLE)
    y = sum(1 for r in results if r.status is Status.ALREADY)
    m = sum(1 for r in results if r.status is Status.MISSING)
    print(f"  applied={a} already={y} missing={m} of {len(results)}",
          file=sys.stderr)


# ---------------------------------------------------------------------------
# Model shorthand
# ---------------------------------------------------------------------------

def expand_model(name: str) -> str:
    """Expand a bare version like '4-7' or '4.7' to 'claude-opus-4-7[1m]'."""
    normalized = name.replace('.', '-')
    if re.fullmatch(r'\d+-\d+', normalized):
        return f'claude-opus-{normalized}[1m]'
    return name


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

def report_exec(argv: list[str]) -> None:
    """Echo the environment delta and command line before exec."""
    for key in sorted(ENV_SET):
        print(f"  {key}={ENV_SET[key]}", file=sys.stderr)
    for key in sorted(ENV_CLEAR):
        if key in os.environ:
            print(f"  unset {key}", file=sys.stderr)
    print(f"  exec {' '.join(argv)}", file=sys.stderr)


def cmd_launch(model: str, extra_args: list[str]) -> None:
    """Patch all discovered binaries, configure environment, exec claude."""
    binaries = discover()
    if not binaries:
        print("claudo-codo: no Claude Code binaries found", file=sys.stderr)
        sys.exit(1)

    any_failed = False
    for path in binaries:
        results, ok = patch_binary(PATCHES, path)
        report_binary(path, results, ok)
        if not ok:
            any_failed = True

    if any_failed:
        print("claudo-codo: refusing to exec — Anthropic likely rephrased "
              "prompts; update PATCHES.", file=sys.stderr)
        sys.exit(1)

    argv = [
        'claude',
        '--dangerously-skip-permissions',
        '--effort', 'max',
        '--model', model,
        *extra_args,
    ]
    report_exec(argv)
    configure_env()
    os.execvp('claude', argv)


def cmd_update() -> None:
    """Let Claude Code update itself without patching or blocking."""
    argv = ['claude']
    report_exec(argv)
    configure_env()
    os.environ.pop('DISABLE_AUTOUPDATER', None)
    os.execvp('claude', argv)


def usage() -> None:
    print("Usage: claudo-codo <subcommand> [args...]", file=sys.stderr)
    print(file=sys.stderr)
    print("Subcommands:", file=sys.stderr)
    print("  <version>   Patch and launch (e.g. 4.6, 4.7)", file=sys.stderr)
    print("  update      Allow Claude Code to update itself", file=sys.stderr)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    if len(sys.argv) < 2:
        usage()
        sys.exit(1)

    subcmd = sys.argv[1]

    if subcmd == 'update':
        cmd_update()
    else:
        cmd_launch(expand_model(subcmd), sys.argv[2:])


if __name__ == '__main__':
    main()
