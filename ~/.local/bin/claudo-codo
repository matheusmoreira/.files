#!/usr/bin/env python3
# SPDX-License-Identifier: AGPL-3.0-or-later

"""claudo-codo — patch Claude Code's native binary, set env, exec claude.

Same-length string replacements in both ASCII and UTF-16 LE encodings;
binary file size never changes.

Idempotent. Backs up to <binary>.original before first patch, and only if
every patch target is present — never backs up a partially-corrupted state.

Quiet on success (one line per binary). Loud on failure (refuses to exec).

To restore:  cp <binary>.original <binary>
Then re-run claudo-codo to repatch.
"""

from __future__ import annotations

import os
import re
import shutil
import sys
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import NamedTuple


# ---------------------------------------------------------------------------
# Encoding support
# ---------------------------------------------------------------------------

# The native binary stores prompt strings in two encodings:
#   ASCII: em-dash appears as the JS escape — (six ASCII bytes)
#   UTF-16 LE: em-dash appears as the actual U+2014 codepoint (two bytes)
#
# Pad units are encoding-aware so trailing-space padding preserves alignment.
ENCODINGS = (
    ('ascii', lambda s: s.replace('—', '\\u2014').encode('ascii'), b' '),
    ('utf16', lambda s: s.encode('utf-16-le'), b' \x00'),
)


# ---------------------------------------------------------------------------
# Patch model
# ---------------------------------------------------------------------------

class Status(Enum):
    APPLICABLE = "OK"
    ALREADY    = "ALREADY"
    MISSING    = "NOT FOUND"


class Result(NamedTuple):
    """Classification of a single patch against a binary."""
    status: Status
    label: str
    occurrences: int


@dataclass(frozen=True)
class Patch:
    """A same-length binary string replacement across multiple encodings.

    Stores patch text as str.  At classify/apply time, encodes to each
    target encoding and pads the replacement to match the original's byte
    length.  Length budget is validated at construction time.
    """

    label: str
    old: str
    new: str

    def __post_init__(self):
        for enc_name, encode, pad_unit in ENCODINGS:
            old_b = encode(self.old)
            new_b = encode(self.new)
            deficit = len(old_b) - len(new_b)
            if deficit < 0:
                raise ValueError(
                    f"{self.label}: replacement exceeds original "
                    f"in {enc_name} ({len(new_b)}B > {len(old_b)}B)"
                )
            if deficit % len(pad_unit) != 0:
                raise ValueError(
                    f"{self.label}: deficit {deficit}B not divisible by "
                    f"pad unit {len(pad_unit)}B in {enc_name}"
                )

    def _encoded_pairs(self):
        """Yield (old_bytes, padded_replacement_bytes) for each encoding."""
        for _, encode, pad_unit in ENCODINGS:
            old_b = encode(self.old)
            new_b = encode(self.new)
            pad_count = (len(old_b) - len(new_b)) // len(pad_unit)
            yield old_b, new_b + pad_unit * pad_count

    def classify(self, data: bytes) -> Result:
        """Classify this patch against binary data.  Pure — no mutation."""
        any_applicable = False
        any_present = False
        total = 0
        for old_b, replacement in self._encoded_pairs():
            n_old = data.count(old_b)
            if n_old > 0:
                any_applicable = True
                total += n_old
            elif old_b != replacement:
                n_new = data.count(replacement)
                if n_new > 0:
                    any_present = True
                    total += n_new
        if any_applicable:
            return Result(Status.APPLICABLE, self.label, total)
        if any_present:
            return Result(Status.ALREADY, self.label, total)
        return Result(Status.MISSING, self.label, 0)

    def apply_to(self, data: bytearray) -> int:
        """Replace all occurrences across all encodings.  Mutates data."""
        count = 0
        for old_b, replacement in self._encoded_pairs():
            if old_b == replacement or data.find(old_b) < 0:
                continue
            i = 0
            while True:
                j = data.find(old_b, i)
                if j < 0:
                    break
                data[j:j + len(old_b)] = replacement
                count += 1
                i = j + len(replacement)
        return count


# ---------------------------------------------------------------------------
