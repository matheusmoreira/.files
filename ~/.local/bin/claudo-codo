#!/usr/bin/env python3
# SPDX-License-Identifier: AGPL-3.0-or-later

"""claudo-codo — patch Claude Code's native binary, set env, exec claude.

Binary patching requires same-length string replacements so no offsets shift
and the file size never changes. Each patch's replacement is right-padded with
spaces to match the original's byte length.

Idempotent. Backs up to <binary>.original before first patch, and only if
every patch target is present — never backs up a partially-corrupted state.

Quiet on success (one line per binary). Loud on failure (refuses to exec).

To restore:  cp <binary>.original <binary>
Then re-run claudo-codo to repatch.
"""

from __future__ import annotations

import os
import re
import shutil
import sys
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import NamedTuple


# ---------------------------------------------------------------------------
# Patch model
# ---------------------------------------------------------------------------

class Status(Enum):
    APPLICABLE = "OK"
    ALREADY    = "ALREADY"
    MISSING    = "NOT FOUND"


class Result(NamedTuple):
    """Classification of a single patch against a binary."""
    status: Status
    label: str
    occurrences: int


@dataclass(frozen=True)
class Patch:
    """A same-length binary string replacement.

    Invariant: len(new) <= len(old).  Enforced at construction time so an
    oversized replacement is caught immediately, not at patch time.
    """

    label: str
    old: bytes
    new: bytes

    def __post_init__(self):
        if len(self.new) > len(self.old):
            raise ValueError(
                f"{self.label}: replacement ({len(self.new)}B) "
                f"exceeds original ({len(self.old)}B)"
            )

    @property
    def replacement(self) -> bytes:
        """The new string, right-padded with spaces to len(old)."""
        return self.new + b' ' * (len(self.old) - len(self.new))

    def classify(self, data: bytes) -> Result:
        """Classify this patch against binary data.  Pure — no mutation."""
        r = self.replacement
        if data.find(r) >= 0:
            return Result(Status.ALREADY, self.label, data.count(r))
        if data.find(self.old) >= 0:
            return Result(Status.APPLICABLE, self.label, data.count(self.old))
        return Result(Status.MISSING, self.label, 0)

    def apply_to(self, data: bytearray) -> int:
        """Replace all occurrences in data (mutates).  Returns count."""
        r = self.replacement
        if data.find(r) >= 0:
            return 0
        count = 0
        i = 0
        while True:
            j = data.find(self.old, i)
            if j < 0:
                break
            data[j:j + len(self.old)] = r
            count += 1
            i = j + len(r)
        return count


# ---------------------------------------------------------------------------
# Patch definitions — add, remove, or reorder entries here.
#
# Em-dashes in the binary appear as the JS escape \\u2014 (six bytes).
#
# To find new targets in a binary:
#   strings <binary> | grep -E '<suspect phrase>'
# ---------------------------------------------------------------------------

