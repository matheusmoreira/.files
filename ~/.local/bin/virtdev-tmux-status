#!/usr/bin/env bash
#
# virtdev-tmux-status <pane-id>
#
# Persistent connection handler for the virtdev tmux status channel.
# Reads Unit Separator (0x1F) delimited records from stdin (one line
# per guest prompt update), renders tmux format codes, and sets
# @shell_status on the target pane.
#
# Invoked by socat via the virtdev-tmux-status@.service template unit.
# The pane ID (numeric, % prefix already stripped) is passed as $1.
#
# SECURITY: the guest is untrusted. The entire parsing path uses bash
# builtins only — no external programs process untrusted data. This
# eliminates the C parser attack surface that jq presented.
#
#   - Numeric fields are regex-checked against ^[0-9]{1,18}$ before
#     any arithmetic context (bash arithmetic eval RCE prevention).
#
#   - String fields have control characters stripped (0x00-0x1F, 0x7F,
#     and C1 controls 0x80-0x9F). Attacker-controlled strings are
#     concatenated directly, never passed through terminal-write's
#     keyword matcher.
#

set -euo pipefail

# shellcheck disable=SC1090
source ~/.local/lib/bash/import
import terminal

pane="${1}"
integer='^[0-9]{1,18}$'

sanitize() {
  local value="$1"
  # Strip C0 control characters (0x00-0x1F), DEL (0x7F), and C1
  # control characters (0x80-0x9F, encoded as 0xC2 0x80-0x9F in UTF-8).
  # Preserves valid UTF-8 text and all printable characters.
  printf '%s' "${value}" | tr -d '\000-\037\177' | LC_ALL=C sed 's/\xc2[\x80-\x9f]//g'
}

while IFS= read -r -n 16384 line; do
  # Parse Unit Separator delimited fields. Fixed order:
  # version, exit, directory, host [, branch, commit, operation,
  # upstream, conflicted, staged, unstaged, untracked, stashed,
  # ahead, behind]
  # Git fields are absent when not in a repository (4 fields only).
  IFS=$'\x1f' read -r version exit_code directory host branch commit operation upstream conflicted staged unstaged untracked stashed ahead behind <<< "${line}"

  # Validate protocol version and numeric fields.
  [[ "${version}" =~ $integer && "${version}" == "1" ]] || continue
  [[ "${exit_code}" =~ $integer ]] || continue

  # Sanitize guest-supplied strings.
  directory="$(sanitize "${directory}")"
  host="$(sanitize "${host}")"

  local_status=''

  # Exit code
  printf -v padded_exit '%3d' "${exit_code}"
  if [[ "${exit_code}" -ne 0 ]]; then
    local_status+="$(terminal-write escape=tmux foreground=red)"
    local_status+="${padded_exit}"
    local_status+="$(terminal-write escape=tmux reset ' ')"
  else
    local_status+="$(terminal-write escape=tmux dim)"
    local_status+="${padded_exit}"
    local_status+="$(terminal-write escape=tmux reset ' ')"
  fi

  # Working directory with hostname
  local_status+="$(terminal-write escape=tmux '[ ' foreground=yellow)"
  local_status+="${host}"
  local_status+="$(terminal-write escape=tmux reset ' ' foreground=green)"
  local_status+="${directory}"
  local_status+="$(terminal-write escape=tmux reset ' ]')"

  # Git (present when more than 4 fields)
  if [[ -n "${branch}${commit}${conflicted}${staged}${unstaged}${untracked}" ]]; then
    # Validate git numeric fields
    [[ "${stashed}" =~ $integer ]] || stashed=0
    [[ "${ahead}" =~ $integer ]] || ahead=0
    [[ "${behind}" =~ $integer ]] || behind=0

    # Sanitize git strings
    branch="$(sanitize "${branch}")"
    commit="$(sanitize "${commit}")"
    operation="$(sanitize "${operation}")"
    upstream="$(sanitize "${upstream}")"

    local_status+=" $(terminal-format ± escape=tmux foreground=yellow)"

    if [[ -n "${operation}" ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=magenta)"
      local_status+="${operation}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    indicators=''
    [[ "${conflicted}" == "true" ]] && indicators+="$(terminal-write escape=tmux foreground=red '!' reset)"
    [[ "${staged}" == "true" ]]     && indicators+="$(terminal-write escape=tmux foreground=green '•' reset)"
    [[ "${unstaged}" == "true" ]]   && indicators+="$(terminal-write escape=tmux foreground=magenta '*' reset)"
    [[ "${untracked}" == "true" ]]  && indicators+="$(terminal-write escape=tmux foreground=blue '?' reset)"
    [[ "${stashed}" -ne 0 ]]        && indicators+="$(terminal-write escape=tmux foreground=cyan '⊙' reset)"

    if [[ -n "${indicators}" ]]; then
      local_status+=" ${indicators}"
    fi

    if [[ -n "${commit}" ]]; then
      local_status+=" $(terminal-write escape=tmux dim foreground=cyan)"
      local_status+="${commit}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ -n "${branch}" ]]; then
      local_status+=" $(terminal-write escape=tmux bright)"
      local_status+="${branch}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ -n "${upstream}" ]]; then
      local_status+=" $(terminal-write escape=tmux dim)"
      local_status+="${upstream}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ "${ahead}" -gt 0 ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=green)"
      local_status+="+${ahead}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi
    if [[ "${behind}" -gt 0 ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=red)"
      local_status+="-${behind}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi
  fi

  tmux set-option -t "%${pane}" -pq @shell_status "${local_status}" 2>/dev/null || true
done
