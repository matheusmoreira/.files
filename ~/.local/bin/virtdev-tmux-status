#!/usr/bin/env bash
#
# virtdev-tmux-status <pane-id>
#
# Persistent connection handler for the virtdev tmux status channel.
# Reads line-delimited JSON from stdin (one object per guest prompt
# update), renders tmux format codes, and sets @shell_status on the
# target pane.
#
# Invoked by socat via the virtdev-tmux-status@.service template unit.
# The pane ID (numeric, % prefix already stripped) is passed as $1.
#
# SECURITY: the guest is untrusted. Every field extracted from the JSON
# is validated or sanitized before use:
#
#   - Numeric fields are regex-checked against ^[0-9]{1,18}$ before any
#     arithmetic context. Bash's [[ -ne ]] and [[ -gt ]] perform
#     arithmetic evaluation which executes command substitutions.
#
#   - String fields have C0/C1 control characters stripped to prevent
#     terminal escape injection (ESC, BEL, etc.) via jq's \uXXXX
#     decoding. Valid UTF-8 text is preserved. Attacker-controlled
#     strings are concatenated directly into the output, never passed
#     through terminal-write's keyword matcher.
#
#   - tmux format codes (#[...] style changes) in guest-supplied strings
#     are cosmetic only — #{@shell_status} without the E: prefix does
#     not recursively expand #(command) or #{variable} sequences, so
#     there is no injection path to code execution or information
#     leakage. The guest already controls the displayed content, so
#     controlling colors is not a meaningful escalation.
#

set -euo pipefail

# shellcheck disable=SC1090
source ~/.local/lib/bash/import
import terminal

pane="${1}"
integer='^[0-9]{1,18}$'

sanitize() {
  local value="$1"
  # Strip C0 control characters (0x00-0x1F), DEL (0x7F), and C1
  # control characters (0x80-0x9F, encoded as 0xC2 0x80-0x9F in UTF-8).
  # Preserves valid UTF-8 text, #, and all printable characters.
  printf '%s' "${value}" | tr -d '\000-\037\177' | LC_ALL=C sed 's/\xc2[\x80-\x9f]//g'
}

while IFS= read -r -n 16384 line; do
  parsed="$(printf '%s' "${line}" | jq -rj '[.version, .exit, .directory, .host, .git.branch // "", .git.commit // "", .git.operation // "", .git.upstream // "", (.git.conflicted | tostring), (.git.staged | tostring), (.git.unstaged | tostring), (.git.untracked | tostring), (.git.stashed // 0 | tostring), (.git.ahead // 0 | tostring), (.git.behind // 0 | tostring), (.git // null | type)] | join("")')" || continue

  IFS=$'\x1f' read -r version exit_code directory host branch commit operation upstream conflicted staged unstaged untracked stashed ahead behind git_type <<< "${parsed}"

  [[ "${version}" =~ $integer && "${version}" == "1" ]] || continue
  [[ "${exit_code}" =~ $integer ]] || continue
  [[ "${stashed}" =~ $integer ]] || continue
  [[ "${ahead}" =~ $integer ]] || continue
  [[ "${behind}" =~ $integer ]] || continue

  directory="$(sanitize "${directory}")"
  host="$(sanitize "${host}")"
  branch="$(sanitize "${branch}")"
  commit="$(sanitize "${commit}")"
  operation="$(sanitize "${operation}")"
  upstream="$(sanitize "${upstream}")"

  local_status=''

  # Exit code
  printf -v padded_exit '%3d' "${exit_code}"
  if [[ "${exit_code}" -ne 0 ]]; then
    local_status+="$(terminal-write escape=tmux foreground=red)"
    local_status+="${padded_exit}"
    local_status+="$(terminal-write escape=tmux reset ' ')"
  else
    local_status+="$(terminal-write escape=tmux dim)"
    local_status+="${padded_exit}"
    local_status+="$(terminal-write escape=tmux reset ' ')"
  fi

  # Working directory with hostname
  local_status+="$(terminal-write escape=tmux '[ ' foreground=yellow)"
  local_status+="${host}"
  local_status+="$(terminal-write escape=tmux reset ' ' foreground=green)"
  local_status+="${directory}"
  local_status+="$(terminal-write escape=tmux reset ' ]')"

  # Git
  if [[ "${git_type}" == "object" ]]; then
    local_status+=" $(terminal-format ± escape=tmux foreground=yellow)"

    if [[ -n "${operation}" ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=magenta)"
      local_status+="${operation}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    indicators=''
    [[ "${conflicted}" == "true" ]] && indicators+="$(terminal-write escape=tmux foreground=red '!' reset)"
    [[ "${staged}" == "true" ]]     && indicators+="$(terminal-write escape=tmux foreground=green '•' reset)"
    [[ "${unstaged}" == "true" ]]   && indicators+="$(terminal-write escape=tmux foreground=magenta '*' reset)"
    [[ "${untracked}" == "true" ]]  && indicators+="$(terminal-write escape=tmux foreground=blue '?' reset)"
    [[ "${stashed}" -ne 0 ]]        && indicators+="$(terminal-write escape=tmux foreground=cyan '⊙' reset)"

    if [[ -n "${indicators}" ]]; then
      local_status+=" ${indicators}"
    fi

    if [[ -n "${commit}" ]]; then
      local_status+=" $(terminal-write escape=tmux dim foreground=cyan)"
      local_status+="${commit}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ -n "${branch}" ]]; then
      local_status+=" $(terminal-write escape=tmux bright)"
      local_status+="${branch}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ -n "${upstream}" ]]; then
      local_status+=" $(terminal-write escape=tmux dim)"
      local_status+="${upstream}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi

    if [[ "${ahead}" -gt 0 ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=green)"
      local_status+="+${ahead}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi
    if [[ "${behind}" -gt 0 ]]; then
      local_status+=" $(terminal-write escape=tmux foreground=red)"
      local_status+="-${behind}"
      local_status+="$(terminal-write escape=tmux reset)"
    fi
  fi

  tmux set-option -t "%${pane}" -pq @shell_status "${local_status}" 2>/dev/null || true
done
