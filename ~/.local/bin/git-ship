#!/usr/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later

# shellcheck disable=SC2310  # in_rebase and resolve_upstream are predicate helpers

set -eo pipefail

name="${GIT_SHIP_NAME:-git ship}"

count=""
peek=false
oneline=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --peek)
      peek=true
      shift
      ;;
    --oneline)
      peek=true
      oneline=true
      shift
      ;;
    *)
      if [[ "$1" =~ ^-([1-9][0-9]*)$ ]]; then
        count="${BASH_REMATCH[1]}"
        shift
      else
        1>&2 echo "${name}: bad argument '$1' (expected -<n>, --peek, or --oneline)"
        exit 64
      fi
      ;;
  esac
done

# Default count: --oneline shows all, otherwise 1.
if [[ -z "${count}" ]]; then
  if "${oneline}"; then
    count=0
  else
    count=1
  fi
fi

gitdir="$(git rev-parse --git-dir)"

in_rebase() {
  [[ -d "${gitdir}/rebase-merge" ]] || [[ -d "${gitdir}/rebase-apply" ]]
}

rebase_state_dir() {
  if [[ -d "${gitdir}/rebase-merge" ]]; then
    printf '%s' "${gitdir}/rebase-merge"
  elif [[ -d "${gitdir}/rebase-apply" ]]; then
    printf '%s' "${gitdir}/rebase-apply"
  else
    return 1
  fi
}

short() { git rev-parse --short=12 "${1}"; }

# Sets branch, remote, merge_ref, remote_branch in caller's scope.
resolve_upstream() {
  branch="$(git symbolic-ref --short --quiet HEAD)" \
    || { 1>&2 echo "${name}: HEAD is detached and not in a rebase"; return 2; }
  remote="$(git config "branch.${branch}.remote")" \
    || { 1>&2 echo "${name}: no upstream remote for ${branch}"; return 2; }
  merge_ref="$(git config "branch.${branch}.merge")" \
    || { 1>&2 echo "${name}: no upstream branch for ${branch}"; return 2; }
  remote_branch="${merge_ref#refs/heads/}"
}

# ── Peek mode: show commits without shipping ──────────────────────────

if "${peek}"; then
  if in_rebase; then
    state="$(rebase_state_dir)"
    msgnum="$(cat "${state}/msgnum" 2>/dev/null || echo 0)"
    end="$(cat "${state}/end" 2>/dev/null || echo '?')"

    commits=("HEAD")
    if [[ "${count}" -ne 1 ]] && [[ -f "${state}/git-rebase-todo" ]]; then
      while IFS= read -r line; do
        [[ "${line}" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line}" ]] && continue
        read -r cmd sha rest <<< "${line}"
        [[ "${cmd}" == "pick" || "${cmd}" == "edit" ]] || continue
        [[ -n "${sha}" ]] || continue
        commits+=("${sha}")
        [[ "${count}" -eq 0 || ${#commits[@]} -lt ${count} ]] || break
      done < "${state}/git-rebase-todo"
    fi

    if "${oneline}"; then
      echo "Step ${msgnum} of ${end}:"
      for sha in "${commits[@]}"; do
        git --no-pager log -1 --format='  %h %s' "${sha}"
      done
    else
      for i in "${!commits[@]}"; do
        step=$((msgnum + i))
        [[ "${i}" -gt 0 ]] && echo
        echo "Commit (step ${step} of ${end}):"
        echo
        git --no-pager show "${commits[${i}]}"
      done
    fi
  else
    resolve_upstream

    mapfile -t all < <(git rev-list --reverse "${remote}/${remote_branch}..HEAD")

    if [[ "${count}" -eq 0 ]]; then
      commits=("${all[@]}")
    else
      commits=("${all[@]:0:${count}}")
    fi

    if [[ ${#commits[@]} -eq 0 ]]; then
      1>&2 echo "${name}: nothing to ship (${branch} matches ${remote}/${remote_branch})"
      exit 1
    fi

    ahead="${#all[@]}"

    if "${oneline}"; then
      echo "${ahead} to ship:"
      for sha in "${commits[@]}"; do
        git --no-pager log -1 --format='  %h %s' "${sha}"
      done
    else
      for i in "${!commits[@]}"; do
        remaining=$((ahead - i))
        [[ "${i}" -gt 0 ]] && echo
        echo "Commit $((i + 1)) of ${#commits[@]} (${remaining} remaining):"
        echo
        git --no-pager show "${commits[${i}]}"
      done
    fi
  fi

  exit 0
fi

# ── Ship mode: single push covering N commits ────────────────────────

if in_rebase; then
  head_name="$(cat "$(rebase_state_dir)/head-name")"
  branch="${head_name#refs/heads/}"
  remote="$(git config "branch.${branch}.remote")"

  before="$(git rev-parse "${remote}/${branch}")"
  last_sha="$(git rev-parse HEAD)"

  # Advance to the Nth edited commit, or stop when the rebase ends.
  for ((j=1; j<count; j++)); do
    in_rebase || break
    git rebase --continue
    last_sha="$(git rev-parse HEAD)"
  done

  # Single push covering all reached commits.
  git push "${remote}" "${last_sha}:${branch}"

  after="$(git rev-parse "${remote}/${branch}")"
  shipped="$(git rev-list --count "${before}..${last_sha}")"
  echo
  if [[ "${shipped}" -eq 1 ]]; then
    echo "Shipped $(short "${last_sha}") \"$(git log -1 --format='%s' "${last_sha}")\""
  else
    echo "Shipped ${shipped} commits:"
    git --no-pager log --format='  %h %s' "${before}..${last_sha}"
  fi
  echo "  ${remote}/${branch}: $(short "${before}") -> $(short "${after}")"

  # Advance to the next commit for review.
  if in_rebase; then
    git rebase --continue
  fi
else
  resolve_upstream

  mapfile -t unpushed < <(git rev-list --reverse "${remote}/${remote_branch}..HEAD")

  if [[ ${#unpushed[@]} -eq 0 ]]; then
    1>&2 echo "${name}: nothing to ship"
    exit 1
  fi

  shipped="${count}"
  if [[ "${shipped}" -gt "${#unpushed[@]}" ]]; then
    shipped="${#unpushed[@]}"
  fi

  target="${unpushed[$((shipped - 1))]}"
  before="$(git rev-parse "${remote}/${remote_branch}")"

  # Single push covering all N commits.
  git push "${remote}" "${target}:${remote_branch}"

  after="$(git rev-parse "${remote}/${remote_branch}")"
  ahead="$(git rev-list --count "${remote}/${remote_branch}..HEAD")"
  echo
  if [[ "${shipped}" -eq 1 ]]; then
    echo "Shipped $(short "${target}") \"$(git log -1 --format='%s' "${target}")\""
  else
    echo "Shipped ${shipped} commits:"
    git --no-pager log --format='  %h %s' "${before}..${target}"
  fi
  echo "  ${remote}/${remote_branch}: $(short "${before}") -> $(short "${after}")"
  echo "  ${branch}: ${ahead} commit(s) ahead of ${remote}/${remote_branch}"
fi

if [[ "${shipped}" -lt "${count}" ]]; then
  1>&2 echo "${name}: shipped ${shipped} of ${count} requested"
fi

# Tail: show the next commit to review / ship, if any.
if in_rebase; then
  state="$(rebase_state_dir)"
  msgnum="$(cat "${state}/msgnum" 2>/dev/null || echo '?')"
  end="$(cat "${state}/end" 2>/dev/null || echo '?')"
  echo
  echo "Next commit to review (step ${msgnum} of ${end}):"
  git --no-pager show HEAD
elif resolve_upstream 2>/dev/null; then
  ahead="$(git rev-list --count "${remote}/${remote_branch}..HEAD" 2>/dev/null || echo 0)"
  if [[ "${ahead}" -gt 0 ]]; then
    next="$(git rev-list "${remote}/${remote_branch}..HEAD" | tail -1)"
    echo
    echo "Next to ship (${ahead} remaining):"
    git --no-pager log -1 --format='  %h %s' "${next}"
  fi
fi
