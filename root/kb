# ---------------------------------------------------------------------------
# Per-LED hardware calibration
#
# Per-channel scale factors as percentages (100 = no change).
# Models sub-pixel efficiency: a green at 80% strength needs
# 125% scale (1/0.8) to compensate.
# ---------------------------------------------------------------------------

declare -A led_calibration=(
  [5]="82 125 100"  # F5: weak green, slightly hot red
)

clamp() {
  local v=$(( $1 ))
  (( v < 0 )) && v=0
  (( v > 255 )) && v=255
  printf '%d' "${v}"
}

calibrate() {
  local led="${1}" r="${2}" g="${3}" b="${4}"
  local scale="${led_calibration[${led}]:-}"

  if [[ -n "${scale}" ]]; then
    read -r sr sg sb <<< "${scale}"
    r=$(clamp $(( r * sr / 100 )))
    g=$(clamp $(( g * sg / 100 )))
    b=$(clamp $(( b * sb / 100 )))
  fi

  printf 'led %d %d %d %d\n' "${led}" "${r}" "${g}" "${b}"
}

# ---------------------------------------------------------------------------
# Color application
# ---------------------------------------------------------------------------

apply-calibration() {
  local -n scheme="${color_scheme}"

  for category in "${all_categories[@]}"; do
    local -n keys="${category}"
    local fallback="${category_fallback[${category}]:-}"
    local color="${scheme[${category}]:-${scheme[${fallback}]:-}}"

    for key in "${keys[@]}"; do
      local led="${keycodes[${key}]}"
      [[ -v "led_calibration[${led}]" ]] || continue
      calibrate "${led}" ${color}
    done
  done
}

apply-colors() {
  local -n scheme="${color_scheme}"

  for category in "${all_categories[@]}"; do
    local -n keys="${category}"
    local fallback="${category_fallback[${category}]:-}"
    local color="${scheme[${category}]:-${scheme[${fallback}]:-}}"

    for key in "${keys[@]}"; do
      calibrate "${keycodes[${key}]}" ${color}
    done
  done
}

