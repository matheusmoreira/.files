# ---------------------------------------------------------------------------
# Color application
# ---------------------------------------------------------------------------

apply-colors() {
  local -n scheme="${color_scheme}"

  for category in "${all_categories[@]}"; do
    local -n keys="${category}"
    local color="${scheme[${category}]}"

    for key in "${keys[@]}"; do
      printf 'led %d %s\n' "${keycodes[${key}]}" "${color}"
    done
  done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

schemes=(neon monokai vaporwave gruvbox nord dracula matrix vim)

usage() {
  cat >&2 <<HELP
Usage: kb [scheme] <command>...

Schemes:  ${schemes[*]}

Commands:
  reset                 Reset keyboard LEDs
  colors                Apply the active color scheme
  off                   Turn LEDs off
  min|low|med|hi|max    Set brightness level

Example: kb reset neon colors
HELP
}

is-scheme() {
  local name="${1}"
  for s in "${schemes[@]}"; do
    [[ "${name}" == "${s}" ]] && return 0
  done
  return 1
}

commands() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -h|--help|help)
        usage
        exit 0
        ;;
      reset)
        printf "%s\n" 'reset'
        sleep 0.2
        shift
        ;;
      off)
        printf "%s\n" 'brightness 0'
        shift
        ;;
      min|minimum)
        printf "%s\n" 'brightness 1'
        shift
        ;;
      low|lo)
        printf "%s\n" 'brightness 3'
        shift
        ;;
      med|medium)
        printf "%s\n" 'brightness 5'
        shift
        ;;
      hi|high)
        printf "%s\n" 'brightness 7'
        shift
        ;;
      max|maximum)
        printf "%s\n" 'brightness 10'
        shift
        ;;
      color|colors)
        apply-colors
        shift
        ;;
      *)
        if is-scheme "${1}"; then
          color_scheme="${1}"
          shift
        else
          printf 'kb: unknown command: %s\n' "${1}" >&2
          exit 1
        fi
        ;;
    esac
  done
}

commands "${@}"
