apply-colors() {
  for key in "${!colors[@]}"; do
    [[ "${key}" == "${color_scheme}."* ]] || continue
    printf 'led %d %s\n' "${keycodes["${key#${color_scheme}.}"]}" "${colors["${key}"]}"
  done
}

commands() {
  while [[ $# -gt 0 ]]; do
    case "${1}" in
      reset)
        printf "%s\n" 'reset'
        sleep 0.2
        shift
        ;;
      off)
        printf "%s\n" 'brightness 0'
        shift
        ;;
      min|minimum)
        printf "%s\n" 'brightness 1'
        shift
        ;;
      low|lo)
        printf "%s\n" 'brightness 3'
        shift
        ;;
      med|medium)
        printf "%s\n" 'brightness 5'
        shift
        ;;
      hi|high)
        printf "%s\n" 'brightness 7'
        shift
        ;;
      max|maximum)
        printf "%s\n" 'brightness 10'
        shift
        ;;
      color|colors)
        apply-colors "${color_scheme}"
        shift
        ;;
      neon)
        color_scheme=neon
        shift
        ;;
      monokai)
        color_scheme=monokai
        shift
        ;;
      vaporwave)
        color_scheme=vaporwave
        shift
        ;;
      *)
	break
	;;
    esac
  done
}

commands "${@}"
