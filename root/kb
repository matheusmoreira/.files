  [keypad.0]=177 [keypad.period]=178 [keypad.enter.2]=179
)

# ---------------------------------------------------------------------------
# Per-LED hardware calibration
#
# Per-channel scale factors as percentages (100 = no change).
# Models sub-pixel efficiency: a green at 80% strength needs
# 125% scale (1/0.8) to compensate.
# ---------------------------------------------------------------------------

declare -A led_calibration=(
  [5]="90 125 100"  # F5: weak green, slightly hot red
)

clamp() {
  local v=$(( $1 ))
  (( v < 0 )) && v=0
  (( v > 255 )) && v=255
  printf '%d' "${v}"
}

calibrate() {
  local led="${1}" r="${2}" g="${3}" b="${4}"
  local scale="${led_calibration[${led}]:-}"

  if [[ -n "${scale}" ]]; then
    read -r sr sg sb <<< "${scale}"
    r=$(clamp $(( r * sr / 100 )))
    g=$(clamp $(( g * sg / 100 )))
    b=$(clamp $(( b * sb / 100 )))
  fi

  printf 'led %d %d %d %d\n' "${led}" "${r}" "${g}" "${b}"
}

# ---------------------------------------------------------------------------
# Color application
# ---------------------------------------------------------------------------

random-flood() {
  local r=$(( RANDOM % 256 ))
  local g=$(( RANDOM % 256 ))
  local b=$(( RANDOM % 256 ))
  flood "${r}" "${g}" "${b}" 1
}

random-per-key() {
  for led in $(unique-leds); do
    calibrate "${led}" "$(( RANDOM % 256 ))" "$(( RANDOM % 256 ))" "$(( RANDOM % 256 ))"
  done
}

rain() {
  trap 'printf "%s\n" "reset"; exit 0' INT

  local all_leds=($(unique-leds))
  local count=${#all_leds[@]}
  local -A brightness=()

  for led in "${all_leds[@]}"; do
    printf 'led %d 5 5 15\n' "${led}"
  done

  while true; do
    for led in "${!brightness[@]}"; do
      local b=$(( brightness[${led}] - 30 ))
      if (( b <= 15 )); then
        printf 'led %d 5 5 15\n' "${led}"
        unset "brightness[${led}]"
      else
        calibrate "${led}" "$(( b * 40 / 100 ))" "$(( b * 80 / 100 ))" "${b}"
        brightness[${led}]=${b}
      fi
    done

    local drops=$(( RANDOM % 3 + 1 ))
    for (( i = 0; i < drops; i++ )); do
      local led="${all_leds[$(( RANDOM % count ))]}"
      brightness[${led}]=255
      calibrate "${led}" 100 200 255
    done

    sleep 0.12
  done
}

apply-colors() {
  local -n scheme="${color_scheme}"

  for category in "${all_categories[@]}"; do
    local -n keys="${category}"
    local fallback="${category_fallback[${category}]:-}"
    local color="${scheme[${category}]:-${scheme[${fallback}]:-}}"

    for key in "${keys[@]}"; do
      calibrate "${keycodes[${key}]}" ${color}
    done
  done
}

# ---------------------------------------------------------------------------
# Interactive calibration
# ---------------------------------------------------------------------------

unique-leds() {
  local -A seen=()
  for led in "${keycodes[@]}"; do
    [[ -v "seen[${led}]" ]] && continue
    seen[${led}]=1
    printf '%d\n' "${led}"
  done
}

flood() {
  local r="${1}" g="${2}" b="${3}" use_cal="${4}"

  for led in $(unique-leds); do
    if [[ "${use_cal}" -eq 1 ]]; then
      calibrate "${led}" "${r}" "${g}" "${b}"
    else
      printf 'led %d %d %d %d\n' "${led}" "${r}" "${g}" "${b}"
    fi
  done
}

led-names() {
  local target="${1}"
  local first=1
  for key in "${!keycodes[@]}"; do
    if [[ "${keycodes[${key}]}" -eq "${target}" ]]; then
      [[ ${first} -eq 0 ]] && printf '/'
      printf '%s' "${key}"
      first=0
    fi
  done
}

resolve-key() {
  local name="${1}"
  if [[ -v "keycodes[${name}]" ]]; then
    printf '%d' "${keycodes[${name}]}"
    return 0
  fi
  return 1
}

interactive-calibration() {
  local r g b cal_on=1

  randomize() {
    r=$(( RANDOM % 256 ))
    g=$(( RANDOM % 256 ))
    b=$(( RANDOM % 256 ))
  }

  status() {
    local cal_str; [[ ${cal_on} -eq 1 ]] && cal_str="ON" || cal_str="OFF"
    printf '\033[1mColor: %3d %3d %3d    Calibration: %s\033[0m\n' \
      "${r}" "${g}" "${b}" "${cal_str}" >&2
  }

  show-help() {
    cat >&2 <<'CALHELP'

  r                    Randomize color
  R G B                Set specific color (0-255)
  c                    Toggle calibration on/off
  KEY SR SG SB         Set calibration for key (percentages, 100=no change)
  d KEY                Delete calibration entry
  p                    Print current calibration table
  q                    Quit and print final settings

  Key names: f1-f12, a-z, 0-9, esc, del, space.1, tab.1,
             shift.left.1, ctrl.left.1, arrows.up, etc.

CALHELP
  }

  print-table() {
    if [[ ${#led_calibration[@]} -eq 0 ]]; then
      printf '  (no calibration entries)\n' >&2
    else
      for led in $(printf '%s\n' "${!led_calibration[@]}" | sort -n); do
        printf '  [%s]="%s"  # %s\n' \
          "${led}" "${led_calibration[${led}]}" "$(led-names "${led}")" >&2
      done
    fi
  }

  printf '\n\033[1mInteractive LED calibration\033[0m\n' >&2
  show-help

  printf "%s\n" 'brightness 10'

  randomize
  flood "${r}" "${g}" "${b}" "${cal_on}"
  status

  while IFS= read -r -p "> " line <&3; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "${line}" ]] && continue

    read -r cmd a1 a2 a3 <<< "${line}"

    case "${cmd}" in
      r)
        randomize
        flood "${r}" "${g}" "${b}" "${cal_on}"
        status
        ;;
      c)
        cal_on=$(( 1 - cal_on ))
        flood "${r}" "${g}" "${b}" "${cal_on}"
        status
        ;;
      d)
        local led
        if [[ -n "${a1}" ]] && led=$(resolve-key "${a1}"); then
          if [[ -v "led_calibration[${led}]" ]]; then
            unset "led_calibration[${led}]"
            printf 'Deleted calibration for %s (LED %d)\n' "${a1}" "${led}" >&2
            flood "${r}" "${g}" "${b}" "${cal_on}"
          else
            printf 'No calibration entry for %s (LED %d)\n' "${a1}" "${led}" >&2
          fi
        else
          printf 'Unknown key: %s\n' "${a1}" >&2
        fi
        ;;
      p)
        print-table
        ;;
      q)
        printf '\nFinal calibration settings for led_calibration:\n' >&2
        print-table
        printf '\n' >&2
        break
        ;;
      h|help|\?)
        show-help
        ;;
      *)
        # Try: KEY SR SG SB (calibration) or R G B (color)
        local led
        if [[ -n "${a3}" ]] && led=$(resolve-key "${cmd}"); then
          led_calibration[${led}]="${a1} ${a2} ${a3}"
          printf '%s (LED %d) calibration: %s%% %s%% %s%%\n' \
            "${cmd}" "${led}" "${a1}" "${a2}" "${a3}" >&2
          flood "${r}" "${g}" "${b}" "${cal_on}"
        elif [[ -n "${a2}" && -z "${a3}" ]] && [[ "${cmd}" =~ ^[0-9]+$ ]]; then
          r="${cmd}" g="${a1}" b="${a2}"
          flood "${r}" "${g}" "${b}" "${cal_on}"
          status
        else
          printf 'Unknown: %s (h for help)\n' "${cmd}" >&2
        fi
        ;;
    esac
  done
} 3</dev/tty

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

declare -A schemes=(
  [neon]=1 [monokai]=1 [vaporwave]=1 [gruvbox]=1
  [nord]=1 [dracula]=1 [matrix]=1   [vim]=1
  [sunset]=1 [ocean]=1 [cyberpunk]=1 [sakura]=1 [stealth]=1
  [tron]=1 [portal]=1 [aurora]=1 [lava]=1 [space]=1
  [ice]=1 [christmas]=1
  [persona5]=1 [halflife]=1 [megaman]=1
  [evangelion]=1 [gits]=1 [bebop]=1
  [bladerunner]=1 [alien]=1 [bioshock]=1
  [dbz]=1 [mgs]=1 [nier]=1 [pacificrim]=1
  [bioluminescence]=1 [nfsu]=1 [unreal]=1
  [obsidian]=1 [amethyst]=1 [jade]=1 [noir]=1
)

usage() {
  cat >&2 <<HELP
Usage: kb [scheme] <command>...

Schemes:  ${!schemes[*]}

Commands:
  reset                 Reset keyboard LEDs
  colors                Apply the active color scheme
  random                Random color, whole keyboard
  party                 Random color per key
  rain                  Animated rain drops (Ctrl+C to stop)
  wave|breathe|scan|blink   Hardware effects
  calibrate             Interactive calibration mode
  off                   Turn LEDs off
  min|low|med|hi|max    Set brightness level

Example: kb reset neon colors
         kb calibrate | sudo ./ite-829x
HELP
}

is-scheme() {
  [[ -v "schemes[${1}]" ]]
}

commands() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -h|--help|help)
        usage
        exit 0
        ;;
      reset)
        printf "%s\n" 'reset'
        sleep 0.2
        shift
        ;;
      off)
        printf "%s\n" 'brightness 0'
        shift
        ;;
      min|minimum)
        printf "%s\n" 'brightness 1'
        shift
        ;;
      low|lo)
        printf "%s\n" 'brightness 3'
        shift
        ;;
      med|medium)
        printf "%s\n" 'brightness 5'
        shift
        ;;
      hi|high)
        printf "%s\n" 'brightness 7'
        shift
        ;;
      max|maximum)
        printf "%s\n" 'brightness 10'
        shift
        ;;
      color|colors)
        apply-colors
        shift
        ;;
      random)
        random-flood
        shift
        ;;
      party)
        random-per-key
        shift
        ;;
      rain)
        rain
        shift
        ;;
      wave)
        printf '%s\n' 'effects 0'
        shift
        ;;
      breathe)
        printf '%s\n' 'effects 1'
        shift
        ;;
      scan)
        printf '%s\n' 'effects 2'
        shift
        ;;
      blink)
        printf '%s\n' 'effects 3'
        shift
        ;;
      calibrate)
        interactive-calibration
        shift
        ;;
      *)
        if is-scheme "${1}"; then
          color_scheme="${1}"
          shift
        else
          printf 'kb: unknown command: %s\n' "${1}" >&2
          exit 1
        fi
        ;;
    esac
  done
}

commands "${@}"
