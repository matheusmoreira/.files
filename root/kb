# ---------------------------------------------------------------------------
# Per-LED hardware calibration
#
# RGB offset applied to compensate for manufacturing variance.
# Values are added to the base color and clamped to [0, 255].
# ---------------------------------------------------------------------------

declare -A led_calibration=(
  [5]="0 30 0"    # F5: weak green sub-pixel
)

clamp() {
  local v=$(( $1 ))
  (( v < 0 )) && v=0
  (( v > 255 )) && v=255
  printf '%d' "${v}"
}

calibrate() {
  local led="${1}" r="${2}" g="${3}" b="${4}"
  local offset="${led_calibration[${led}]:-}"

  if [[ -n "${offset}" ]]; then
    read -r dr dg db <<< "${offset}"
    r=$(clamp $(( r + dr )))
    g=$(clamp $(( g + dg )))
    b=$(clamp $(( b + db )))
  fi

  printf 'led %d %d %d %d\n' "${led}" "${r}" "${g}" "${b}"
}

# ---------------------------------------------------------------------------
# Color application
# ---------------------------------------------------------------------------

apply-colors() {
  local -n scheme="${color_scheme}"

  for category in "${all_categories[@]}"; do
    local -n keys="${category}"
    local fallback="${category_fallback[${category}]:-}"
    local color="${scheme[${category}]:-${scheme[${fallback}]:-}}"

    for key in "${keys[@]}"; do
      calibrate "${keycodes[${key}]}" ${color}
    done
  done
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

declare -A schemes=(
  [neon]=1 [monokai]=1 [vaporwave]=1 [gruvbox]=1
  [nord]=1 [dracula]=1 [matrix]=1   [vim]=1
  [sunset]=1 [ocean]=1 [cyberpunk]=1 [sakura]=1 [stealth]=1
)

usage() {
  cat >&2 <<HELP
Usage: kb [scheme] <command>...

Schemes:  ${!schemes[*]}

Commands:
  reset                 Reset keyboard LEDs
  colors                Apply the active color scheme
  off                   Turn LEDs off
  min|low|med|hi|max    Set brightness level

Example: kb reset neon colors
HELP
}

is-scheme() {
  [[ -v "schemes[${1}]" ]]
}

commands() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -h|--help|help)
        usage
        exit 0
        ;;
      reset)
        printf "%s\n" 'reset'
        sleep 0.2
        shift
        ;;
      off)
        printf "%s\n" 'brightness 0'
        shift
        ;;
      min|minimum)
        printf "%s\n" 'brightness 1'
        shift
        ;;
      low|lo)
        printf "%s\n" 'brightness 3'
        shift
        ;;
      med|medium)
        printf "%s\n" 'brightness 5'
        shift
        ;;
      hi|high)
        printf "%s\n" 'brightness 7'
        shift
        ;;
      max|maximum)
        printf "%s\n" 'brightness 10'
        shift
        ;;
      color|colors)
        apply-colors
        shift
        ;;
      *)
        if is-scheme "${1}"; then
          color_scheme="${1}"
          shift
        else
          printf 'kb: unknown command: %s\n' "${1}" >&2
          exit 1
        fi
        ;;
    esac
  done
}

commands "${@}"
