  [bladerunner]=1 [alien]=1 [bioshock]=1
  [dbz]=1 [mgs]=1 [nier]=1
)

usage() {
  cat >&2 <<HELP
Usage: kb [scheme] <command>...

Schemes:  ${!schemes[*]}

Commands:
  reset                 Reset keyboard LEDs
  colors                Apply the active color scheme
  calibrate             Reapply only calibrated LEDs
  off                   Turn LEDs off
  min|low|med|hi|max    Set brightness level

Example: kb reset neon colors
HELP
}

is-scheme() {
  [[ -v "schemes[${1}]" ]]
}

commands() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -h|--help|help)
        usage
        exit 0
        ;;
      reset)
        printf "%s\n" 'reset'
        sleep 0.2
        shift
        ;;
      off)
        printf "%s\n" 'brightness 0'
        shift
        ;;
      min|minimum)
        printf "%s\n" 'brightness 1'
        shift
        ;;
      low|lo)
        printf "%s\n" 'brightness 3'
        shift
        ;;
      med|medium)
        printf "%s\n" 'brightness 5'
        shift
        ;;
      hi|high)
        printf "%s\n" 'brightness 7'
        shift
        ;;
      max|maximum)
        printf "%s\n" 'brightness 10'
        shift
        ;;
      color|colors)
        apply-colors
        shift
        ;;
      calibrate)
        apply-calibration
        shift
        ;;
      *)
        if is-scheme "${1}"; then
          color_scheme="${1}"
          shift
        else
          printf 'kb: unknown command: %s\n' "${1}" >&2
          exit 1
        fi
        ;;
    esac
  done
}

commands "${@}"
